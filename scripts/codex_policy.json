{
  "mode": "review_planning_only",
  "codex_exec_flags": [
    "--full-auto",
    "--sandbox",
    "workspace-write"
  ],
  "allowed_write_paths": [
    "manager/",
    "eval/",
    "handoff/latest_status.json"
  ],
  "forbidden_write_paths": [
    "src/",
    "app/",
    "backend/",
    "frontend/",
    "*.py",
    "*.ts",
    "*.js"
  ],
  "default_owner": "openclaw",
  "planning_executor": "openclaw",
  "codex_role": "planning_and_review",
  "constraints": {
    "codex_must_not_modify_code": true,
    "codex_must_not_control_scheduler": true
  }
}